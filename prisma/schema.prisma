  name          String
  password_hash String?
  designation   String?
  mine_cd       String?
  plot_id       String?
  verified_at   DateTime?
  entry_ts      DateTime       @default(now())
  updt_ts       DateTime
  entry_by      String?
  updt_by       String?
  auth_session  auth_session[]

  @@schema("public")
}

